# MantraOne Local Development Environment
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
DATABASE_URL=postgresql+asyncpg://mantraone:mantraone_dev_password@localhost:5432/mantraone_dev
REDIS_URL=redis://localhost:6379
ENCRYPTION_KEY=your_base64_32_byte_key_here
ENVIRONMENT=development
LOCAL_DEV_MODE=true
FIREBASE_MOCK_ENABLED=true
LOCAL_STORAGE_PATH=/tmp/mantraone_storage
LOG_LEVEL=INFO
APP_VERSION=0.1.0
COGNEE_DB_PATH=/tmp/mantraone_cognee
COORDINATOR_CHECKIN_HOUR=6
MAX_CHECKINS_PER_DAY=2
WATCHER_LOOKBACK_HOURS=48
WATCHER_EVALUATION_INTERVAL_MINUTES=60
ESCALATION_COOLDOWN_DAYS=7
